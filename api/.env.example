# ===========================================
# SIEM Home Lab API Server — Environment Config
# ===========================================

# --- Wazuh Manager Connection ---
WAZUH_HOST=https://localhost          # Wazuh Manager URL (include https://)
WAZUH_PORT=55000                       # Wazuh REST API port
WAZUH_USER=wazuh-wui                   # Wazuh API username
WAZUH_PASS=MyS3cr3tP@ssw0rd           # Wazuh API password

# --- API Server ---
PORT=3001                              # Port for this API server
NODE_ENV=production                    # production | development

# --- Authentication ---
JWT_PRIVATE_KEY_BASE64="insert-base64-private-key"
JWT_PUBLIC_KEY_BASE64="insert-base64-public-key"
REFRESH_TOKEN_SECRET="change-me-to-a-random-64-char-string"
ADMIN_DEFAULT_PASSWORD="Admin@123!"
ANALYST_DEFAULT_PASSWORD="Analyst@123!"
VIEWER_DEFAULT_PASSWORD="Viewer@123!"

# --- CORS ---
REACT_APP_URL=http://localhost:3000    # Frontend origin for CORS

# --- Logging ---
LOG_LEVEL=info                         # error | warn | info | debug
